      ]
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from sklearn.ensemble import IsolationForest\n",
        "\n",
        "np.random.seed(42)\n",
        "\n",
        "time = np.arange(1, 101)\n",
        "\n",
        "# Normal temperature readings\n",
        "temp = np.random.normal(35, 2, 100)\n",
        "\n",
        "# Normal vibration readings\n",
        "vibration = np.random.normal(10, 1, 100)\n",
        "\n",
        "# Add anomalies\n",
        "temp[20] = 55\n",
        "temp[60] = 60\n",
        "\n",
        "vibration[30] = 25\n",
        "vibration[80] = 28\n",
        "\n",
        "data = pd.DataFrame({\n",
        "    \"Time\": time,\n",
        "    \"Temperature\": temp,\n",
        "    \"Vibration\": vibration\n",
        "})\n",
        "\n",
        "print(data.head())\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "\n",
        "plt.plot(data[\"Time\"], data[\"Temperature\"], label=\"Temperature\")\n",
        "plt.plot(data[\"Time\"], data[\"Vibration\"], label=\"Vibration\")\n",
        "\n",
        "plt.title(\"IoT Sensor Monitoring Dashboard\")\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Sensor Values\")\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "model = IsolationForest(contamination=0.05, random_state=42)\n",
        "\n",
        "data[\"Anomaly\"] = model.fit_predict(data[[\"Temperature\", \"Vibration\"]])\n",
        "\n",
        "anomalies = data[data[\"Anomaly\"] == -1]\n",
        "print(anomalies)\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "\n",
        "plt.plot(data[\"Time\"], data[\"Temperature\"], label=\"Temperature\")\n",
        "plt.scatter(anomalies[\"Time\"], anomalies[\"Temperature\"], color='red', label=\"Anomaly\")\n",
        "\n",
        "plt.title(\"Temperature Anomaly Detection\")\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Temperature\")\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(10,5))\n",
        "\n",
        "plt.plot(data[\"Time\"], data[\"Vibration\"], label=\"Vibration\")\n",
        "plt.scatter(anomalies[\"Time\"], anomalies[\"Vibration\"], color='red', label=\"Anomaly\")\n",
        "\n",
        "plt.title(\"Vibration Anomaly Detection\")\n",
        "plt.xlabel(\"Time\")\n",
        "plt.ylabel(\"Vibration\")\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "for i in anomalies.index:\n",
        "    print(f\"⚠ ALERT: Anomaly detected at Time {data['Time'][i]}\")\n"
      ],
